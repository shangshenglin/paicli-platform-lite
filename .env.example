# Optional REST API protection. Set a long random value for private deployment.
# The default listener is loopback-only. A non-loopback address requires PAICLI_API_KEY.
PAICLI_SERVER_ADDRESS=127.0.0.1
PAICLI_API_KEY=change-this-before-deployment
# Recommended for every non-development deployment. Startup fails if the key is blank.
PAICLI_SECURITY_REQUIRE_API_KEY=true
# Protect /actuator/** and /v3/api-docs with the same key.
PAICLI_SECURITY_PROTECT_MANAGEMENT=true

# Offline demo provider is the default.
PAICLI_MODEL_PROVIDER=demo

# OpenAI-compatible provider example:
# PAICLI_MODEL_PROVIDER=openai-compatible
# PAICLI_MODEL_BASE_URL=https://api.openai.com/v1
# PAICLI_MODEL_API_KEY=replace-me
# PAICLI_MODEL_NAME=gpt-4o-mini
# PAICLI_MODEL_MAX_CONTEXT_TOKENS=128000
# PAICLI_MODEL_MAX_OUTPUT_TOKENS=4096

# GLM example:
# PAICLI_MODEL_PROVIDER=openai-compatible
# PAICLI_MODEL_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# PAICLI_MODEL_API_KEY=replace-me
# PAICLI_MODEL_NAME=glm-4.5

# DeepSeek V4 example (recommended for this Agent runtime):
# PAICLI_MODEL_PROVIDER=openai-compatible
# PAICLI_MODEL_BASE_URL=https://api.deepseek.com
# PAICLI_MODEL_API_KEY=replace-me
# PAICLI_MODEL_NAME=deepseek-v4-flash
# PAICLI_MODEL_MAX_CONTEXT_TOKENS=1000000
# PAICLI_MODEL_MAX_OUTPUT_TOKENS=16384
# PAICLI_MODEL_THINKING_MODE=enabled
# PAICLI_MODEL_REASONING_EFFORT=high
# PAICLI_MODEL_MAX_ATTEMPTS=3
# PAICLI_MODEL_RETRY_BASE_MILLIS=500
# PAICLI_MODEL_REQUESTS_PER_MINUTE=60
# PAICLI_MODEL_FALLBACK_NAME=
# PAICLI_MODEL_MAX_RUN_STEPS=30
# PAICLI_MODEL_MAX_RUN_TOKENS=200000
# PAICLI_MODEL_STREAM_IDLE_TIMEOUT_SECONDS=45
# PAICLI_MODEL_CIRCUIT_FAILURE_THRESHOLD=5
# PAICLI_MODEL_CIRCUIT_OPEN_SECONDS=30
# PAICLI_MODEL_MAX_RUN_DURATION_SECONDS=1800
# PAICLI_MODEL_MAX_TOOL_CALLS_PER_TURN=16
# PAICLI_MODEL_MAX_TOOL_CALLS_PER_RUN=100
# Use deepseek-v4-pro and reasoning effort max only for harder, higher-cost tasks.

# Optional Server-side web tools. PAICLI_WEB_SEARCH_URL should expose a
# SearXNG-compatible JSON response with a `results` array.
# PAICLI_WEB_ENABLED=true
# PAICLI_WEB_SEARCH_URL=https://search.example.com/search
# PAICLI_WEB_SEARCH_API_KEY=replace-me
# PAICLI_WEB_SEARCH_API_KEY_HEADER=Authorization

# RAG defaults to a local deterministic hashing vector. Optional semantic embeddings:
# PAICLI_RAG_EMBEDDING_PROVIDER=ollama
# PAICLI_RAG_EMBEDDING_BASE_URL=http://127.0.0.1:11434
# PAICLI_RAG_EMBEDDING_MODEL=nomic-embed-text:latest
# Or use openai-compatible plus PAICLI_RAG_EMBEDDING_API_KEY.
# PAICLI_RAG_AUTO_RETRIEVE=true
# PAICLI_RAG_AUTO_TOP_K=5
# Image-only PDFs are rendered and transcribed with the configured multimodal model.
# PAICLI_RAG_PDF_OCR_ENABLED=true
# PAICLI_RAG_PDF_OCR_MAX_PAGES=6
# PAICLI_RAG_PDF_OCR_DPI=150
# PAICLI_MEMORY_AUTO_EXTRACT=true
# PAICLI_MEMORY_RETRIEVAL_TOP_K=8
# PAICLI_MEMORY_MIN_CONFIDENCE=0.65

# Single-node maintenance. WAL checkpoint runs hourly; Event/Audit default to 30/90 days.
# PAICLI_MAINTENANCE_INTERVAL_MILLIS=3600000
# PAICLI_EVENT_RETENTION_DAYS=30
# PAICLI_AUDIT_RETENTION_DAYS=90
# PAICLI_ORPHAN_FILE_GRACE_HOURS=24
# PAICLI_SQLITE_VACUUM_ENABLED=false
