          "requiredTools": ["spawn_agent"],
          "forbiddenTools": ["write_file", "execute_command", "cancel_agent"],
          "requiredResponse": ["AGENT_SPAWNED"],
          "forbiddenResponse": ["PAICLI_MODEL_API_KEY"],
          "maxToolCalls": 3,
          "maxTokens": 2000,
          "maxDurationMs": 180000,
          "enabled": false
